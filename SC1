(function () {
  'use strict';

  const BTN_ID = 'pingid-button';
  const CHECK_EVERY_MS = 500;   // كل قدّاش يشيّك
  const STOP_AFTER_MS = 30000;  // يوقف بعد 30 ثانية (بدّلها إذا بغيتي)

  const start = Date.now();
  const timer = setInterval(() => {
    const el = document.getElementById(BTN_ID);

    if (el) {
      // حماية: ما ينقرش إلا إذا باين ومفعّل
      const isVisible = !!(el.offsetWidth || el.offsetHeight || el.getClientRects().length);
      const isDisabled = el.hasAttribute('disabled') || el.getAttribute('aria-disabled') === 'true';

      if (isVisible && !isDisabled) {
        clearInterval(timer);

        // إذا كان <a> قد تحتاج dispatch click طبيعي
        el.click();

        // Debug اختياري
        console.log('[VM] Clicked #' + BTN_ID);
      }
    }

    if (Date.now() - start > STOP_AFTER_MS) {
      clearInterval(timer);
      console.log('[VM] Stop: timeout waiting for #' + BTN_ID);
    }
  }, CHECK_EVERY_MS);
})();
